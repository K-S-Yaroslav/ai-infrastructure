# ===== ОСНОВНЫЕ НАСТРОЙКИ =====
N8N_HOST=your-domain.ngrok-free.dev
N8N_PROTOCOL=https
WEBHOOK_URL=https://your-domain.ngrok-free.dev
N8N_WEBHOOK_URL=https://your-domain.ngrok-free.dev

# ===== БАЗА ДАННЫХ =====
POSTGRES_USER=n8n_admin
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=n8n_db

# ===== БЕЗОПАСНОСТЬ =====
N8N_ENCRYPTION_KEY=CHANGE_ME_32_CHARS
REDIS_PASSWORD=CHANGE_ME

# ===== КАК СОЗДАТЬ КЛЮЧИ =====
# N8N_ENCRYPTION_KEY: openssl rand -hex 16
# REDIS_PASSWORD: openssl rand -hex 8