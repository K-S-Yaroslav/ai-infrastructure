# ===== ОСНОВНЫЕ НАСТРОЙКИ =====
# Домен для n8n (замените на свой ngrok домен)
N8N_HOST=your-domain.ngrok-free.dev
N8N_PROTOCOL=https
WEBHOOK_URL=https://your-domain.ngrok-free.dev
N8N_WEBHOOK_URL=https://your-domain.ngrok-free.dev

# ===== БАЗА ДАННЫХ =====
POSTGRES_USER=n8n_admin
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=n8n_db

# ===== БЕЗОПАСНОСТЬ =====
N8N_ENCRYPTION_KEY=CHANGE_ME_32_CHARS
QDRANT_API_KEY=CHANGE_ME
REDIS_PASSWORD=CHANGE_ME

# ===== ИНТЕРФЕЙСЫ =====
FLOWISE_USERNAME=admin
FLOWISE_PASSWORD=CHANGE_ME
FLOWISE_SECRETKEY=CHANGE_ME
WEBUI_SECRET_KEY=CHANGE_ME

# ===== МОНИТОРИНГ =====
GRAFANA_USER=admin
GRAFANA_PASSWORD=CHANGE_ME
